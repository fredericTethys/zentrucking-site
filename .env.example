# Journey planning API endpoint (see src/lib/journeyApi.ts for the request/response contract).
# When unset, the driver journey calculator falls back to a client-side illustrative estimate.
VITE_JOURNEY_API_URL=

# Optional bearer token / API key sent as `Authorization: Bearer <token>` to the journey API.
VITE_JOURNEY_API_KEY=

# Supabase / ZenConnect — contact form (shared with zenteck.ai).
# OPTIONAL: the app falls back to the known public project values in
# src/lib/supabase.ts, so the form works without setting these. Override here
# (or in Netlify env) to point at a different environment or rotate the key.
# The anon key is PUBLIC by design (protected by Row Level Security).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
